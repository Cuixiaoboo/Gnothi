{
  "identifier": "com.gnothi.app",
  "version": "0.2.2",
  "productName": "Gnothi",
  "build": {
    "beforeDevCommand": "npm --prefix ./frontend run dev",
    "beforeBuildCommand": "npm --prefix ./frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gnothi - 知识管理",
        "minWidth": 1200,
        "minHeight": 768,
        "maxWidth": 1200,
        "maxHeight": 768,
        "resizable": false,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
